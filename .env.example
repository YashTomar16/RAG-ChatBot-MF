# Groq API — required for factual answer generation (Phase 4)
GROQ_API_KEY=gsk-your-key-here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Embeddings — local BGE (free, no API key required)
EMBEDDING_PROVIDER=bge
# Model: auto picks bge-small or bge-large from chunk count/size
# Or set explicitly: bge-small | bge-large | BAAI/bge-small-en-v1.5 | BAAI/bge-large-en-v1.5
EMBEDDING_MODEL=auto

# Retriever settings (Phase 4+)
TOP_K=5
SIMILARITY_THRESHOLD=0.7
RETRIEVAL_FETCH_K=8
GENERATOR_CONTEXT_CHUNKS=3
SCHEME_BOOST=0.15
SECTION_PRIMARY_BOOST=0.10
SECTION_SECONDARY_BOOST=0.05
AMBIGUITY_SCORE_GAP=0.05

# Scheduler timezone (Phase 5+)
TIMEZONE=Asia/Kolkata

# Groq request timeout in seconds (Phase 7+)
GROQ_TIMEOUT_SECONDS=30

# FastAPI CORS — comma-separated frontend origins (Vercel + local dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app
